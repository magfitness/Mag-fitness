<script>
const IG_HANDLE = 'magfitness.studio';
document.getElementById('yr').textContent = new Date().getFullYear();

function selectProgram(name, price) {
  const select = document.getElementById('program');
  for (let i = 0; i < select.options.length; i++) {
    if (select.options[i].value.startsWith(name)) { select.selectedIndex = i; break; }
  }
  updateTotal();
  setTimeout(() => { document.getElementById('order').scrollIntoView({ behavior: 'smooth' }); }, 100);
}

function updateTotal() {
  const select = document.getElementById('program');
  const summary = document.getElementById('summary');
  const eftPanel = document.getElementById('eftPanel');
  const btcPanel = document.getElementById('btcPanel');
  const discountRow = document.getElementById('discountRow');
  const proofLabel = document.getElementById('proofLabel');
  if (!select.value) { summary.style.display = 'none'; return; }
  const [name, priceStr] = select.value.split('|');
  const price = parseInt(priceStr);
  const isBtc = document.getElementById('payBtc').checked;
  const total = isBtc ? Math.round(price * 0.8) : price;
  summary.style.display = 'block';
  document.getElementById('sumProgram').textContent = name;
  document.getElementById('sumPrice').textContent = 'R' + price.toLocaleString();
  if (isBtc) {
    discountRow.style.display = 'flex';
    document.getElementById('sumDiscount').textContent = '— R' + (price - total).toLocaleString();
    document.getElementById('sumTotal').textContent = 'R' + total.toLocaleString();
    document.getElementById('sumTotal').className = 'summary-val btc';
    eftPanel.classList.remove('active'); btcPanel.classList.add('active');
    proofLabel.textContent = 'Bitcoin Transaction ID (paste TXID here after sending)';
  } else {
    discountRow.style.display = 'none';
    document.getElementById('sumTotal').textContent = 'R' + total.toLocaleString();
    document.getElementById('sumTotal').className = 'summary-val';
    btcPanel.classList.remove('active'); eftPanel.classList.add('active');
    proofLabel.textContent = 'Proof of Payment Reference (optional — DM screenshot after)';
  }
  const nameEl = document.getElementById('name');
  const code = name.split(' ')[0];
  document.getElementById('eftRef').textContent = nameEl.value
    ? nameEl.value.split(' ')[0] + ' ' + code
    : 'Your Name + ' + code;
}

document.getElementById('name').addEventListener('input', updateTotal);

function copyText(text, btn) {
  navigator.clipboard.writeText(text).then(() => {
    const orig = btn.innerHTML;
    btn.innerHTML = '✓ Copied';
    btn.style.background = btn.classList.contains('btc') ? 'var(--btc)' : 'var(--ox)';
    btn.style.color = btn.classList.contains('btc') ? '#000' : 'var(--bone)';
    setTimeout(() => { btn.innerHTML = orig; btn.style.background = ''; btn.style.color = ''; }, 1800);
  });
}

function submitOrder(e) {
  e.preventDefault();
  const select = document.getElementById('program');
  if (!select.value) { alert('Please select a program first.'); return false; }
  const [program, priceStr] = select.value.split('|');
  const price = parseInt(priceStr);
  const isBtc = document.getElementById('payBtc').checked;
  const total = isBtc ? Math.round(price * 0.8) : price;
  const name = document.getElementById('name').value;
  const email = document.getElementById('email').value;
  const ig = document.getElementById('instagram').value;
  const proof = document.getElementById('proof').value;
  const method = isBtc ? '₿ Bitcoin (20% off)' : 'EFT to ABSA';
  const message =
    `Hi Matthew, I'd like to order:\n\n` +
    `Program: ${program}\nTotal: R${total.toLocaleString()}\nPayment: ${method}\n\n` +
    `Name: ${name}\nEmail: ${email}\nInstagram: ${ig}\n\n` +
    (proof ? `Payment Reference / TXID:\n${proof}\n\n` : `I'll send proof of payment after this DM.\n\n`) +
    `Please confirm and send my MAG Fitness program.`;
  const igUrl = `https://ig.me/m/${IG_HANDLE}?text=${encodeURIComponent(message)}`;
  window.open(igUrl, '_blank');
  setTimeout(() => { alert('Your order has been prepared.\n\nIf Instagram did not open, please DM @' + IG_HANDLE + ' directly with your order details.'); }, 800);
  return false;
}

document.addEventListener('keydown', function(e){
  if ((e.ctrlKey || e.metaKey) && (e.key === 'a' || e.key === 'A' || e.key === 's' || e.key === 'S' || e.key === 'p' || e.key === 'P')) {
    if (!e.target.matches('input, textarea, select')) e.preventDefault();
  }
});

const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity = '1';
      e.target.style.transform = 'translateY(0)';
    }
  });
}, { threshold: 0.06 });
document.querySelectorAll('.prog-card, .step, .why-col, .support-card').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(16px)';
  el.style.transition = 'opacity .55s ease, transform .55s ease, border-color .25s';
  obs.observe(el);
});
</script>

